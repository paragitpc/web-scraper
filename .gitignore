# ============================================
# .gitignore - Proyecto contable-uy-backfill
# ============================================

# === SECRETOS Y CREDENCIALES (CRÍTICO) ===
.env
.env.*
*.env
secrets/
credentials/
*.key
*.pem
*.token
*token*
*secret*
*credential*
config.local.*
*.private

# === DATOS SCRAPEADOS (NO van al repo público) ===
data/
datos/
output/
salida/
downloads/
descargas/
*.pdf
*.json
*.jsonl
*.csv
*.parquet
*.db
*.sqlite
*.sqlite3
cache/
.cache/

# === LOGS ===
*.log
logs/
*.log.*

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Entornos virtuales ===
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# === Jupyter ===
.ipynb_checkpoints
*.ipynb

# === Editores / IDEs ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Sistema operativo ===
.directory
.Trash-*

# === Playwright ===
playwright-report/
test-results/
.playwright/

# === Pytest ===
.pytest_cache/
.coverage
htmlcov/

# === Archivos personales ===
PERSONAL/
personal/
notas_*.txt
TODO_personal*

